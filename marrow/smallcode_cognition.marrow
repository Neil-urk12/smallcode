// SmallCode Cognition Layer — MarrowScript declarations
// Compiles to TypeScript runtime in src/compiled/cognition/ + src/compiled/providers/
//
// Phase A: classify_task_type (replaces hand-rolled classifyTask)
// Phase B: compress_history (replaces hand-rolled compaction)
// Phase C: code_assist with router (replaces hand-rolled chatCompletion)
// Phase D: full agent loop (long term)

system SmallCodeCognition {
  domain: cognitive_scaffold

  // ─── Models ────────────────────────────────────────────────────────────────

  model TinyClassifier {
    provider: openai_compat
    endpoint: "${SMALLCODE_BASE_URL}"
    name: "${SMALLCODE_MODEL}"
    context_window: 8192
    max_output: 64
    temperature: 0.0
    cost_class: tiny
    latency_class: fast
  }

  model SmallCoder {
    provider: openai_compat
    endpoint: "${SMALLCODE_BASE_URL}"
    name: "${SMALLCODE_MODEL}"
    context_window: 32000
    max_output: 4096
    temperature: 0.1
    cost_class: small
    latency_class: medium
  }

  model MediumCoder {
    provider: openai_compat
    endpoint: "${SMALLCODE_BASE_URL}"
    name: "${SMALLCODE_MODEL_STRONG}"
    context_window: 32000
    max_output: 8192
    temperature: 0.1
    cost_class: medium
    latency_class: medium
  }

  // ─── Router (deterministic complexity-based dispatch) ──────────────────────

  router coding_router {
    by: input.complexity
    tier trivial { max: 0.3 -> TinyClassifier }
    tier simple  { max: 0.6 -> SmallCoder }
    tier complex {           -> MediumCoder }
    on_low_confidence: escalate
    confidence_threshold: 0.6
    fallback: MediumCoder
  }

  // ─── Extension Points ──────────────────────────────────────────────────────

  extension_point tmpl_classify_task(user_message: string) {
    returns: string
    stable: true
  }

  extension_point tmpl_compress_history(history: string, max_tokens: uint) {
    returns: string
    stable: true
  }

  extension_point tmpl_code_assist(task: string, context: string, complexity: float) {
    returns: string
    stable: true
  }

  // ─── Phase A: Task Classifier ──────────────────────────────────────────────

  prompt classify_task_type(user_message: string) {
    model: TinyClassifier
    template: "extension_point:tmpl_classify_task"
    returns: string
    timeout: 3s
    idempotent: true
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 100ms }
    cache: { key: hash(user_message), ttl: 10m }
    constraints: [
      output in ["coding", "editing", "search", "shell", "explanation", "multi_step", "debugging", "backend"]
    ]
  }

  // ─── Phase B: History Compression ──────────────────────────────────────────

  prompt compress_history(history: string, max_tokens: uint) {
    model: SmallCoder
    template: "extension_point:tmpl_compress_history"
    returns: string
    timeout: 30s
    idempotent: true
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 500ms }
    constraints: [
      output.length <= max_tokens
    ]
  }

  // ─── Phase C: Code Assist (router-based) ───────────────────────────────────

  prompt code_assist(task: string, context: string, complexity: float) {
    router: coding_router
    template: "extension_point:tmpl_code_assist"
    returns: string
    timeout: 120s
    validate: schema_only
    on_invalid: retry_with_repair_prompt
    retry: { max_attempts: 3, backoff: exponential, interval: 1s }
  }

  // ─── Policy ────────────────────────────────────────────────────────────────

  policy cognition_limits {
    rate_limit: 120 per 1m
    audit: true
    cost_budgets: [
      {
        scope: per_user
        window: 1h
        cap_tokens: 500000
        on_exceeded: { action: error, code: "TOKEN_LIMIT" }
      }
    ]
  }
}
